# Template de configuração — copie para .env e preencha
#   cp .env.example .env
#
# Garmin Connect credentials
EMAIL=
GARMIN_EMAIL=
PASSWORD=
GARMIN_PASSWORD=

# Optional — path where OAuth tokens are persisted after first login
GARMINTOKENS=~/.garminconnect

# Optional — set to "true" for China region accounts (garmin.cn)
GARMIN_IS_CN=false

# Optional — login chain timeout in seconds (BUG-004 fix)
GARMIN_LOGIN_TIMEOUT=180
