# Credenciais Garmin Connect (obrigatórias)
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Região China (true para garmin.cn)
GARMIN_IS_CN=false

# Timeout total da cadeia de login em segundos
GARMIN_LOGIN_TIMEOUT=180

# Porta do dashboard no host
DASHBOARD_PORT=8000

# ---- InfluxDB (F6-02) ----
INFLUX_PORT=8086
INFLUX_USER=admin
INFLUX_PASSWORD=changeme123
INFLUX_ORG=garmin
INFLUX_BUCKET=metrics
INFLUX_TOKEN=garmin-admin-token

# ---- Grafana (F6-04) ----
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ---- Coletor automático (scheduler) ----
# Intervalo entre coletas em segundos (default 900 = 15min).
# Reduza para debug; aumente se atingir rate limit Garmin.
COLLECT_INTERVAL_S=900
